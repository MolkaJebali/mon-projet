<!DOCTYPE html>
<html>
<head>
    <title>Liste des Auteurs</title>
</head>
<body>
    <h1>Liste des Auteurs</h1>

    {# 2.4 Condition si tableau vide #}
    {% if authors is empty %}
        <p>Aucun auteur trouvé.</p>
    {% else %}
        {# 2.6 Nombre d'auteurs #}
        <p>Nombre d'auteurs : {{ authors|length }}</p>

        {# 2.7 Nombre total de livres #}
        {% set total_books = 0 %}
        {% for author in authors %}
            {% set total_books = total_books + author.nb_books %}
        {% endfor %}
        <p>Nombre total de livres : {{ total_books }}</p>

        <table border="1">
            <tr>
                <th>Photo</th>
                <th>Nom</th>
                <th>Email</th>
                <th>Nombre de livres</th>
                <th>Action</th>
            </tr>
            {% for author in authors %}
            <tr>
                <td>
                    <img src="{{ asset(author.picture) }}" alt="{{ author.username }}" width="50">
                </td>
                <td>
                    {# 2.5 Afficher le nom en majuscule #}
                    {{ author.username|upper }}
                </td>
                <td>{{ author.email }}</td>
                <td>{{ author.nb_books }}</td>
                <td>
                    {# 2.8 Lien details #}
                    <a href="{{ path('app_author_details', {'id': author.id}) }}">
                        Details
                    </a>
                </td>
            </tr>
            {% endfor %}
        </table>
    {% endif %}
</body>
</html>